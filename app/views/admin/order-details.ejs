<!-- <input type="hidden" id="fontSize" value="<%=config.fontSize%>"> -->
<div class="card">
  <div class="card-header text-center"><h3>Detalhes do Pedido</h3></div>
  <div class="card-body card-block">

    <!-- Nav tabs -->
    <ul class="nav nav-tabs">
      <!-- <li class="nav-item">
        <a class="nav-link active" data-toggle="tab" href="#home">Pedido</a>
      </li> -->
      <li class="nav-item">
        <a class="nav-link active" data-toggle="tab" href="#menu1">Pedido</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" data-toggle="tab" href="#menu2">Ítems</a>
      </li>

    </ul>

    <!-- Tab panes -->
    <div class="tab-content">

      <div class="tab-pane container active" id="menu1">

        <div class="card">

          <div class="card-header">
            <div class="text-center">
              <h4>Código do Pedido: <%=order.id%></h4>
            </div>
          </div>

          <div class="card-body">
            <!-- <p>Informações Principais</p> -->
            <table class="table table-bordered table-hover">
              <tr>
                <td>Data/Hora do Pedido</td>
                <td><%=order._datetime.toLocaleString('br')%></td>
              </tr>
              <tr>
                <td>Status do Pedido</td>
                <td>
                  <% if(order.status == 0) { %>
                  <div class="no-fulfilled">Em Andamento</div>
                  <% } else { %>
                    <div class="fulfilled">Encerrado</div>
                  <% } %>
                </td>
              </tr>
            </table>
            <!-- <p>Informações de Entrega</p> -->
            <hr>
            <table class="table table-bordered table-hover" id="deliveryAddres">  
              <tr>
                <td>Cod. Pedido</td>
                <td id="orderId"><%=order.id%></td>
              </tr>
              <tr>
                <td>Cliente</td>
                <td id="clientName"><%=order.clientName%></td>
              </tr> 
              <tr>
                <td>Método de Pagamento</td>
                <%if(order.paymentMethod != 'money') {%>
                  <td id="paymentMethod"><%=Order.fixPaymentMethod(order.paymentMethod)%></td>
                <% } %>
              </tr>    
              
              <tr>
                <td>Total</td>
                <td id="total"><%=order.total.toLocaleString('pt-br', {style: 'currency', currency: 'BRL'})%></td>
              </tr>
              <tr>
                <td>Taxa de Entrega</td>
                <td id='delivery_fee'><%=order.delivery_fee.toLocaleString('pt-br', {style: 'currency', currency: 'BRL'})%></td>
              </tr>
              
              <tr>
                <td>Logradouro</td>
                <td id="publicPlace"><%=order.street%></td>
              </tr>
              <tr>
                <td>Número</td>
                <td id="_number"><%=order._number%></td>
              </tr>
              <tr>
                <td>Bairro</td>
                <td id="neighborhood"><%=order.neighborhood%></td>
              </tr>             
            </table>

          </div>
          
        </div>

      </div> <!--End Tab-->

      <div class="tab-pane container" id="menu2">

        <div class="card">

          <div class="card-header">
            <div class="text-center">
              <h4>Itens do Pedido</h4>
            </div>
          </div>

          <div class="card-body">
            
            <% for(let item of items) {%>
              <div class="container">
                <p class="h5"><%=item.name%></p>
                <table class="table table-bordered table-hover">
                  <!--order id that is a reference for all fields-->
                  <input type="hidden" id="oi_id" value="<%=item.oi_id%>">
                  <tr>
                    <td>Código do Produto</td>
                    <td>
                      <input type="text" class="form-control" 
                        readonly id="<%=item.oi_id%>_cod" 
                        value="<%=item.p_id%>">                      
                    </td>
                  </tr>
                  
                  <tr>
                    <td>Preço</td>
                    <td>
                      <input type="text" class="form-control" 
                        readonly id="<%=item.oi_id%>_price" 
                        value="<%=item.price.toLocaleString('pt-br', {style: 'currency', currency: 'BRL'})%>">                      
                    </td>
                  </tr>

                  <tr>
                    <td>Quantidade</td>
                    <td>
                      <input type="text" class="form-control" 
                        readonly id="<%=item.oi_id%>_quantity" 
                        value="<%=item.quantity%>">                      
                    </td>
                  </tr>

                  <tr>
                    <td>Sub Total</td>
                    <td>
                      <input type="text" class="form-control" 
                        readonly id="<%=item.oi_id%>_price" 
                        value="<%=item.subTotal.toLocaleString('pt-br', {style: 'currency', currency: 'BRL'})%>">                      
                    </td>
                  </tr>
                  
                </table> 
              </div>  
              <hr>           
            <% } %>
            
          </div>

        </div>

      </div>

      <div class="container">
        <div class="card-footer">
            <div class="row">
              <div class="col-sm-3">
                <button class="form-control btn btn-info">
                  Atendido</button>
              </div>
              <div class="col-sm-3">
                <button class="form-control btn btn-danger">
                  Deletar</button>
              </div>
            </div>
          </div>
      </div>

    </div>

  </div>
</div>